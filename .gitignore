# ── Dependencies ──────────────────────────────────────────────
node_modules/
frontend/node_modules/
backend/node_modules/

# ── Environment files (contain secrets — never commit) ────────
# Keep `.env.example` as a checked-in template; ignore everything else.
.env
.env.*
!.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example
backend/.env
backend/.env.*
!backend/.env.example

# ── Build / distribution artifacts ────────────────────────────
build/
dist/
out/
frontend/build/
frontend/dist/
backend/build/
backend/dist/

# ── Archives (zipped builds, snapshots) ───────────────────────
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
backend/logs/
backend/airapi.log

# ── Local caches / tooling ────────────────────────────────────
.cache/
.parcel-cache/
.vite/
.eslintcache
.tsbuildinfo
*.tsbuildinfo
coverage/

# ── OS / editor cruft ─────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo
*~
