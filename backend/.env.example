# ─────────────────────────────────────────────────────────────────────
# TravelDesk Backend — Environment Template
# Copy this file to `.env.development` (local) or `.env.production` (deploy)
# and fill in real values. The loader at src/config/env.js picks the file
# based on NODE_ENV; falls back to `.env` for shared defaults.
# ─────────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# ── Database (Postgres) ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=traveldesk_v3
DB_USER=postgres
DB_PASSWORD=changeme

# ── Auth ─────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-long-random-string
JWT_EXPIRES_IN=8h

# ── Uploads ──────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# ── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=info
# SEQ_URL=http://localhost:5341
# SEQ_API_KEY=

# ── Email (SMTP) — optional ──────────────────────────────────────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="TravelDesk <noreply@example.com>"

# ── Flight Provider ──────────────────────────────────────────────────
# Values: mock | amadeus | airapi
FLIGHT_PROVIDER=mock
# AMADEUS_CLIENT_ID=
# AMADEUS_CLIENT_SECRET=

# ── PPI Wallet (partner) ─────────────────────────────────────────────
PPI_API_URL=http://localhost:5100/api/external/wallet
PPI_PARTNER_KEY=
PPI_PARTNER_SECRET=
# Comma-separated PPI product UUIDs — sent as the `productIds` array on create.
PPI_PRODUCT_IDS=917e8079-7e5a-4ebd-a1f1-4be637daf0a5
# PPI_PROGRAM_ID=

# ── AIR API (booking partner) ────────────────────────────────────────
AIRAPI_BASE_URL=
AIRAPI_AIR_PATH=/airlinehost/AirAPIService.svc/JSONService
AIRAPI_TRADE_PATH=/tradehost/TradeAPIService.svc/JSONService
AIRAPI_USER_ID=
AIRAPI_PASSWORD=
AIRAPI_IP_ADDRESS=
AIRAPI_IMEI_NUMBER=000000000000000
AIRAPI_TIMEOUT_MS=30000
AIRAPI_MAX_RETRIES=2
AIRAPI_RETRY_DELAY_MS=600
